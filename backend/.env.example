# LED Backend Configuration

# Database
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=led_db
DB_PORT=5432

# Redis
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# Security
JWT_SECRET=your_super_secret_key_change_me
ARGON2_SALT=optional_static_salt_or_empty

# Mercado Pago
MP_ACCESS_TOKEN=your_mp_access_token
MP_PUBLIC_KEY=your_mp_public_key
WEBHOOK_SECRET=your_mp_webhook_secret

# Server
PORT=8080
ENV=development # development, production
